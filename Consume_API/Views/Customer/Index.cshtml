@model IEnumerable<Consume_API.Models.Customer>
@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<div class="container">
    <div class="row">
        <div class="col-10 offset-1">
            <a class="btn btn-sm btn-primary m-2 p-2 float-end" asp-action="AddCustomer" asp-controller="Customer">Add Customer</a>
            <table class="table table-bordered table-striped table-hover">
                <thead class="bg-dark text-light text-center">
                    <tr>
                        <th>Id</th>
                        <th>Name</th>
                        <th>Gender</th>
                        <th>Active</th>
                        <th>Operation</th>
                    </tr>
                </thead>
                <tbody class="text-center">
                    @if(Model.Count() > 0)
                    {
                        @foreach (var d in Model)
                        {
                            <tr>
                                <td>@d.Id</td>
                                <td>@d.Name</td>
                                <td>@d.Gender</td>
                                <td>@d.IsActive</td>
                                <td>
                                    <a class="btn btn-sm btn-primary" asp-action="Edit" asp-controller="Customer" asp-route-id="@d.Id">Edit</a>
                                    <a class="btn btn-sm btn-warning" asp-action="Details" asp-controller="Customer" asp-route-id="@d.Id" onclick="return confirm('Are you sure, You want to delete this.')">Details</a>
                                    <a class="btn btn-sm btn-danger" asp-action="Delete" asp-controller="Customer" asp-route-id="@d.Id">Delete</a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

